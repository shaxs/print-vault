
# Print Vault Environment Variables
# This file contains sensitive information and should NOT be shared.

# 1. Django Secret Key
# Generate a new key here: https://djecrety.ir/
DJANGO_SECRET_KEY='your-super-secret-key-goes-here'

# 2. Debug Mode
# Set to False in production for security but can be enabled if needed for troubleshooting.
DJANGO_DEBUG='False'

# 3. PostgreSQL Database Username
# The username for the PostgreSQL database.
POSTGRES_USER='postgres'

# 4. PostgreSQL Database Password
# It's highly recommended to change this from the default.
# Generate a password at https://www.rfctools.com/postgresql-password-generator/
POSTGRES_PASSWORD='your-secure-password-goes-here'

# 5. Application Hostname/IP
# This should be the IP address or domain name you use to access the app.
APP_HOST='192.168.68.126'

# 6. Allowed Hosts
# Comma-separated list of allowed hostnames/IPs (no spaces!)
# Add your Tailscale domain here: 192.168.68.126,your-name.ts.net,localhost
ALLOWED_HOSTS='192.168.68.126,localhost,127.0.0.1'

# 7. Application Port
# The external port the application will be accessible on.
APP_PORT='5173'

# 8. STL/3MF Library Share (optional)
# Only needed if you use the file library to scan STL/3MF files from a mounted
# network share or local folder. Leave both unset to skip the feature.
#
# LIBRARY_HOST_PATH  = the path ON THE DOCKER HOST to your library folder.
#                      For an LXC/NAS setup this is the bind-mounted share,
#                      e.g. /mnt/nas/stls.
# LIBRARY_MOUNT_PATH = the path INSIDE the container. This MUST match the path
#                      you enter as the library root in Print Vault's settings.
#                      Defaults to /mnt/nas/stls if unset.
#
# This pair mounts ONE host directory. You can still have several libraries
# from it: point it at a parent folder and add each subfolder as its own root
# in the settings UI (e.g. mount /mnt/nas, then add roots /mnt/nas/stls,
# /mnt/nas/minis). For genuinely SEPARATE mounts (e.g. two different NAS
# boxes), add extra volume entries by hand — and add them to BOTH the backend
# and qcluster services, since the scan runs in the qcluster worker. Put those
# in a docker-compose.override.yml so app upgrades don't overwrite them.
#
# LIBRARY_HOST_PATH='/mnt/nas/stls'
# LIBRARY_MOUNT_PATH='/mnt/nas/stls'

# 9. Background worker tuning (optional — safe defaults for low-end hardware)
# Print Vault renders STL/3MF thumbnails in a background worker. The defaults
# are tuned for the WEAKEST supported hardware (Raspberry Pi / small LXC): the
# first index of a large library is the heaviest thing the app does, and the
# priority is that it must never exhaust a small box's RAM. Slower is fine;
# raise these on capable hardware (NAS/server with plenty of RAM) to index
# faster. All three take effect after a restart/rebuild of the qcluster service.
#
# Q_WORKERS = number of parallel background workers (default 1). Each worker
#     multiplies peak memory, so only raise it if you have RAM to spare
#     (e.g. 2-4 on an 8 GB+ machine). 1 is the safe floor.
# Q_WORKER_MEMORY_LIMIT_MB = recycle a worker once it exceeds this resident
#     memory, in MB (default 600). Also the mid-scan threshold at which a
#     worker hands its remaining files to a fresh task to reclaim memory.
# LIBRARY_MAX_RENDER_FILE_SIZE_MB = skip thumbnail rendering for meshes larger
#     than this on disk, in MB (default 100). Lowering it on constrained
#     hardware prevents a single huge model from spiking memory; those files
#     still appear in the library, just without a generated preview.
# LIBRARY_MAX_RENDER_FACES = skip rendering a mesh with more than this many
#     triangles (default 2000000). On-disk size doesn't bound face count for
#     compressed .3mf or multi-part models, and render memory/time scale with
#     face count, so this is the real guard against one dense mesh OOMing the
#     worker. Lower it on a Pi for a tighter ceiling (fewer previews).
# LIBRARY_MAX_3MF_UNCOMPRESSED_MB = skip a .3mf whose uncompressed contents
#     exceed this, in MB (default 500), checked before loading so a decompression
#     bomb can't OOM during load. Lower it on constrained hardware.
# LIBRARY_RENDER_HEADROOM_MB = the hard backstop. Each thumbnail is rendered in
#     a separate subprocess whose memory is capped at (its startup size + this
#     headroom), in MB (default 2048). Any file that would allocate past the cap
#     is skipped instead of exhausting RAM — this is what makes a runaway
#     physically impossible, whatever the file. Lower it on a small box (e.g.
#     1024 on a 2-4 GB Pi); raise it if legit large models get skipped.
# LIBRARY_RENDER_TIMEOUT_SECONDS = kill a single render that runs longer than
#     this, in seconds (default 120), so one pathological mesh can't wedge the
#     worker. The file is skipped.
#
# Q_WORKERS='1'
# Q_WORKER_MEMORY_LIMIT_MB='600'
# LIBRARY_MAX_RENDER_FILE_SIZE_MB='100'
# LIBRARY_MAX_RENDER_FACES='2000000'
# LIBRARY_MAX_3MF_UNCOMPRESSED_MB='500'
# LIBRARY_RENDER_HEADROOM_MB='2048'
# LIBRARY_RENDER_TIMEOUT_SECONDS='120'